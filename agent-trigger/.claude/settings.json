{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node /project/hooks/hotel_narrator.mjs post_tool_use",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node /project/hooks/hotel_narrator.mjs subagent_start",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node /project/hooks/hotel_narrator.mjs subagent_stop",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
