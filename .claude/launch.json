{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "agent-portal",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": [".claude/proxy.mjs"],
      "port": 3091,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "agent-trigger",
      "runtimeExecutable": "${userHome}/.bun/bin/bun",
      "runtimeArgs": ["run", "agent-trigger/src/server.ts"],
      "port": 3004
    }
  ]
}
