RCON_HOST=127.0.0.1
RCON_PORT=3001
DB_HOST=127.0.0.1
DB_PORT=13306
DB_NAME=arcturus
DB_USER=arcturus_user
DB_PASSWORD=arcturus_pw
# Optional internal fallback (mainly for local debugging)
MCP_API_KEY=
MCP_ALLOW_STATIC_API_KEY_FALLBACK=false
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3003
HABBO_BASE_URL=http://127.0.0.1:1080

# Single source for MCP: RCON, DB, API key. Cursor mcp.json does not need env for habbo.

# Hook: spawn bots in-hotel on Cursor agent events
HABBO_HOOK_ENABLED=false
# Hook transport mode:
# - remote (default): call hosted hook receiver, no local MCP runtime needed
# - local: run hook actions locally using habbo-mcp tools
# - auto: try remote first, then local fallback
HABBO_HOOK_TRANSPORT=remote
# Remote relay target base URL (relay appends /hooks/events)
HABBO_HOOK_REMOTE_BASE_URL=https://hotel-mcp.fixdev.nl
# Optional bearer token for remote hook relay (falls back to MCP_API_KEY)
# HABBO_HOOK_REMOTE_TOKEN=
# Optional for remote/server MCP usage (Cursor hook runtime -> remote MCP HTTP endpoint)
# Default is https://hotel-mcp.fixdev.nl/ when not set.
# HABBO_HOOK_MCP_BASE_URL=https://your-hotel-domain
# Optional fixed room fallback when operator room lookup is unavailable
# HABBO_HOOK_ROOM_ID=202
