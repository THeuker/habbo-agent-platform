# Root-level .dockerignore — applied when build context is . (project root)
# Prevents large unrelated service directories from being sent to the Docker daemon.

# Heavy unrelated services
nitro/
emulator/
mysql/
docs/
scripts/
hooks/
portal-dist/

# All node_modules anywhere in the tree
**/node_modules

# Portal build output (rebuilt inside the image)
portal/dist

# Agent trigger compiled output
agent-trigger/dist

# Git and editor metadata
.git/
.github/
**/.DS_Store
**/npm-debug.log
